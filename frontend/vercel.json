{
  "version": 2,
  "name": "smart-expense-analyzer-frontend",
  "builds": [
    {
      "src": "package.json",
      "use": "@vercel/static-build",
      "config": {
        "distDir": "dist"
      }
    }
  ],
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "env": {
    "VITE_API_URL": "https://smartpersonalexpenseanalyzerspea.onrender.com"
  },
  "build": {
    "env": {
      "VITE_API_URL": "https://smartpersonalexpenseanalyzerspea.onrender.com"
    }
  }
}
